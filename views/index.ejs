<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WEST SERVER | الموقع الرسمي</title>
    <style>
        :root { --main-color: #f39c12; --bg-dark: rgba(0,0,0,0.9); }
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Segoe UI', sans-serif; background: #000; }
        
        .background-container {
            background: url('/images/bg.jpg') no-repeat center center fixed;
            background-size: cover; height: 100vh; width: 100%;
            transition: filter 0.5s ease; position: absolute; z-index: 1;
        }
        .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 2; }

        header { position: relative; z-index: 3; text-align: center; padding-top: 50px; }
        .logo-main { width: 160px; filter: drop-shadow(0 0 10px var(--main-color)); }

        .burger-icon {
            position: fixed; top: 35px; right: 35px; z-index: 100; cursor: pointer;
            display: flex; flex-direction: column; gap: 7px;
        }
        .burger-icon span { width: 35px; height: 4px; background: var(--main-color); border-radius: 2px; }

        .modal {
            display: none; position: fixed; z-index: 90; left: 0; top: 0;
            width: 100%; height: 100%; background-color: rgba(0,0,0,0.85);
            backdrop-filter: blur(15px);
        }

        .modal-content {
            margin: 2% auto; padding: 40px; width: 90%; max-width: 1100px;
            color: white; position: relative; height: 85vh; overflow-y: auto;
        }

        .close-btn { color: var(--main-color); float: left; font-size: 45px; cursor: pointer; }

        .tabs-nav { display: flex; justify-content: center; gap: 40px; border-bottom: 2px solid #333; padding-bottom: 20px; }
        .tabs-nav button { background: none; border: none; color: white; cursor: pointer; font-size: 24px; font-weight: bold; }
        .tabs-nav button.active { color: var(--main-color); border-bottom: 3px solid var(--main-color); }

        .market-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 20px; }
        .market-card { background: #151515; padding: 20px; border-radius: 12px; border-top: 4px solid var(--main-color); position: relative; }
        
        .buy-btn { 
            background: #27ae60; color: white; border: none; padding: 10px; 
            border-radius: 5px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px;
            text-decoration: none; display: block; text-align: center;
        }
        .del-btn { background: #e74c3c; color: white; border: none; padding: 8px; border-radius: 5px; cursor: pointer; width: 100%; margin-top: 5px; }

        .input-group { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 10px; margin-bottom: 20px; text-align: center; }
        .input-group input { padding: 12px; border-radius: 5px; border: none; margin: 5px; width: 30%; }
        .publish-btn { background: var(--main-color); border: none; padding: 12px 25px; cursor: pointer; font-weight: bold; border-radius: 5px; }

        .discord-login { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); z-index: 10; background: #7289da; color: white; padding: 12px 30px; border-radius: 50px; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>

    <div class="background-container" id="bg"></div>
    <div class="overlay"></div>

    <header>
        <img src="/images/logo.png" class="logo-main" alt="WEST">
        <h1 style="color: white; text-shadow: 2px 2px 5px #000;">WEST SERVER</h1>
    </header>

    <div class="burger-icon" onclick="openMenu()">
        <span></span><span></span><span></span>
    </div>

    <% if (!user) { %>
        <a href="/auth/discord" class="discord-login">تسجيل الدخول بالديسكورد</a>
    <% } %>

    <div id="mainModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeMenu()">&times;</span>
            
            <div class="tabs-nav">
                <button onclick="showTab('rules')" id="btn-rules" class="active">القوانين</button>
                <button onclick="showTab('market')" id="btn-market">المتجر 🛒</button>
            </div>

            <div id="rules" class="tab-content" style="display: block;">
                <h2>📜 قوانين WEST</h2>
                <div style="font-size: 22px; line-height: 2;">
                    <p>• يمنع التخريب والـ DM.</p>
                    <p>• الالتزام بالواقعية التامة.</p>
                    <p>• احترام اللاعبين والإدارة.</p>
                </div>
            </div>

            <div id="market" class="tab-content" style="display: none;">
                <h2>🛒 متجر اللاعبين</h2>
                
                <% if (user) { %>
                <div class="input-group">
                    <h3>نشر عرض جديد باسم: <%= user.username %></h3>
                    <input type="text" id="itemName" placeholder="اسم السلعة...">
                    <input type="text" id="itemPrice" placeholder="السعر...">
                    <button class="publish-btn" onclick="publishOffer()">نشر العرض</button>
                </div>
                <% } %>

                <div class="market-grid" id="marketItems">
                    <% offers.slice().reverse().forEach(offer => { %>
                        <div class="market-card" id="offer-<%= offer.id %>">
                            <h4><%= offer.itemName %></h4>
                            <p>البائع: <%= offer.username %></p>
                            <p style="color:var(--main-color); font-weight:bold;">السعر: <%= offer.itemPrice %></p>
                            
                            <a href="https://discord.com/users/<%= offer.userId %>" target="_blank" class="buy-btn">شراء (فتح شات)</a>
                            
                            <% if (user && user.id === offer.userId) { %>
                                <button class="del-btn" onclick="deleteOffer('<%= offer.id %>')">حذف عرضي 🗑️</button>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openMenu() {
            document.getElementById("mainModal").style.display = "block";
            document.getElementById("bg").style.filter = "blur(15px)";
        }
        function closeMenu() {
            document.getElementById("mainModal").style.display = "none";
            document.getElementById("bg").style.filter = "none";
        }
        function showTab(tabId) {
            document.getElementById('rules').style.display = (tabId === 'rules') ? 'block' : 'none';
            document.getElementById('market').style.display = (tabId === 'market') ? 'block' : 'none';
            document.getElementById('btn-rules').classList.toggle('active', tabId === 'rules');
            document.getElementById('btn-market').classList.toggle('active', tabId === 'market');
        }

        async function publishOffer() {
            const itemName = document.getElementById('itemName').value;
            const itemPrice = document.getElementById('itemPrice').value;
            if(!itemName || !itemPrice) return alert("أدخل البيانات!");

            const res = await fetch('/add-offer', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ itemName, itemPrice })
            });
            if(res.ok) location.reload();
        }

        async function deleteOffer(id) {
            if(!confirm("حذف العرض؟")) return;
            const res = await fetch('/delete-offer', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ id })
            });
            if(res.ok) document.getElementById('offer-'+id).remove();
        }
    </script>
</body>
</html>